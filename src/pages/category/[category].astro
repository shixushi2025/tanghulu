---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ItemCard from '../../components/ItemCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { category: 'film' } },
    { params: { category: 'book' } },
    { params: { category: 'tool' } },
    { params: { category: 'health' } },
    { params: { category: 'podcast' } },
    { params: { category: 'other' } },
  ];
}

const { category } = Astro.params;

const allItems = await getCollection('items');
const filtered = allItems
  .filter(i => i.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryLabels: Record<string, string> = {
  film:    '电影',
  book:    '书籍',
  tool:    'AI 工具',
  health:  '健康',
  podcast: '播客',
  other:   '其他',
};

const tabs = [
  { key: 'all',     label: '全部',    href: '/' },
  { key: 'film',    label: '电影',    href: '/category/film' },
  { key: 'book',    label: '书籍',    href: '/category/book' },
  { key: 'tool',    label: 'AI 工具', href: '/category/tool' },
  { key: 'health',  label: '健康',    href: '/category/health' },
  { key: 'podcast', label: '播客',    href: '/category/podcast' },
];

const label = categoryLabels[category] ?? '其他';
---

<BaseLayout title={label}>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-stone-900">{label}</h1>
    <p class="text-stone-400 mt-1">{filtered.length} 条推荐</p>
  </div>

  <div class="flex gap-2 mb-8 overflow-x-auto pb-1">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class={`shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors ${
          tab.key === category ? 'bg-stone-900 text-white' : 'text-stone-600 hover:bg-stone-100'
        }`}
      >
        {tab.label}
      </a>
    ))}
  </div>

  {filtered.length === 0 ? (
    <div class="text-center py-20 text-stone-400">
      <p class="text-4xl mb-4">🍡</p>
      <p>这个分类还没有内容，敬请期待</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {filtered.map(item => (
        <ItemCard
          title={item.data.title}
          category={item.data.category}
          tags={item.data.tags}
          rating={item.data.rating}
          summary={item.data.summary}
          cover={item.data.cover}
          slug={item.id}
        />
      ))}
    </div>
  )}
</BaseLayout>
