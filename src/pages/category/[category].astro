---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ItemCard from '../../components/ItemCard.astro';
import { getCollection } from 'astro:content';
import { allCategories, visibleCategories, categoryConfig } from '../../lib/categories';

export async function getStaticPaths() {
  return allCategories.map(category => ({ params: { category } }));
}

const { category } = Astro.params;
const cat = categoryConfig[category] ?? categoryConfig.other;

const allItems = await getCollection('items');
const filtered = allItems
  .filter(i => i.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={cat.label}>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-stone-900">{cat.label}</h1>
    <p class="text-stone-400 mt-1">{filtered.length} 条</p>
  </div>

  <!-- Tabs: 只显示主要分类 -->
  <div class="flex gap-2 mb-8 overflow-x-auto pb-1">
    <a href="/" class="shrink-0 px-4 py-2 rounded-full text-sm font-medium text-stone-600 hover:bg-stone-100 transition-colors">全部</a>
    {visibleCategories.map(key => (
      <a
        href={`/category/${key}`}
        class={`shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors ${
          key === category ? 'bg-stone-900 text-white' : 'text-stone-600 hover:bg-stone-100'
        }`}
      >
        {categoryConfig[key].label}
      </a>
    ))}
  </div>

  {filtered.length === 0 ? (
    <div class="text-center py-20 text-stone-400">
      <div class="flex justify-center mb-4">
        <img src="/favicon.svg" alt="" class="w-12 h-12 opacity-30" />
      </div>
      <p>还没有这个分类的内容</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {filtered.map(item => (
        <ItemCard
          title={item.data.title}
          category={item.data.category}
          tags={item.data.tags}
          rating={item.data.rating}
          summary={item.data.summary}
          cover={item.data.cover}
          slug={item.id}
          country={item.data.country}
        />
      ))}
    </div>
  )}
</BaseLayout>
