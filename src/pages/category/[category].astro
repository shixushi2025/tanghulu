---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ItemCard from '../../components/ItemCard.astro';
import { categoryConfig } from '../../lib/categories';
import { getItemsByCategory } from '../../lib/db';

const { category } = Astro.params;
const cat = categoryConfig[category] ?? categoryConfig.other;

const db = Astro.locals.runtime.env.TANGHULU_DB;
const items = await getItemsByCategory(db, category);
---

<BaseLayout title={cat.label}>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-stone-900">{cat.label}</h1>
    <p class="text-stone-400 mt-1">{items.length} 条</p>
  </div>

  {items.length === 0 ? (
    <div class="text-center py-20 text-stone-400">
      <div class="flex justify-center mb-4">
        <img src="/favicon.svg" alt="" class="w-12 h-12 opacity-30" />
      </div>
      <p>还没有这个分类的内容</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map(item => (
        <ItemCard
          title={item.title}
          category={item.category}
          tags={item.tags}
          summary={item.summary}
          cover={item.cover}
          slug={item.id}
          country={item.country}
        />
      ))}
    </div>
  )}
</BaseLayout>
