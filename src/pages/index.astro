---
import BaseLayout from '../layouts/BaseLayout.astro';
import ItemCard from '../components/ItemCard.astro';
import { visibleCategories, categoryConfig } from '../lib/categories';

import { getAllItems, countByCategory } from '../lib/db';

const db = Astro.locals.runtime.env.TANGHULU_DB;
const [items, counts] = await Promise.all([getAllItems(db), countByCategory(db)]);

const colors: Record<string, string> = {
  film: 'text-orange-500', book: 'text-green-500', tool: 'text-blue-500',
  health: 'text-rose-500', podcast: 'text-amber-500',
};
---

<BaseLayout>
  <!-- Hero -->
  <div class="text-center pt-16 pb-12">
    <h1 class="text-4xl sm:text-5xl font-bold text-stone-900 mb-3 tracking-tight">精选那些值得你时间的东西</h1>
    <p class="text-stone-400 text-sm">持续收集中</p>
    <div class="flex justify-center flex-wrap gap-8 mt-8">
      {visibleCategories.map((key, i) => (
        <>
          {i > 0 && <div class="w-px bg-stone-200 hidden sm:block self-center h-6"></div>}
          <a href={`/category/${key}`} class="text-center hover:opacity-70 transition-opacity">
            <div class={`text-2xl font-bold ${colors[key]}`}>{counts[key] ?? 0}</div>
            <div class="text-sm text-stone-400 mt-0.5">{categoryConfig[key].label}</div>
          </a>
        </>
      ))}
    </div>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {items.map(item => (
      <ItemCard
        title={item.title}
        category={item.category}
        tags={item.tags}
        summary={item.summary}
        cover={item.cover}
        slug={item.id}
        country={item.country}
      />
    ))}
  </div>
</BaseLayout>
