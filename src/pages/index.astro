---
import BaseLayout from '../layouts/BaseLayout.astro';
import ItemCard from '../components/ItemCard.astro';
import { getCollection } from 'astro:content';
import { visibleCategories, categoryConfig } from '../lib/categories';

const allItems = await getCollection('items');
const sorted = allItems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout>
  <!-- Hero -->
  <div class="text-center pt-16 pb-12">
    <h1 class="text-4xl sm:text-5xl font-bold text-stone-900 mb-3 tracking-tight">精选那些值得你时间的东西</h1>
    <p class="text-stone-400 text-sm">持续收集中</p>
    <div class="flex justify-center flex-wrap gap-8 mt-8">
      {(() => {
        const colors = {
          film: 'text-orange-500', book: 'text-green-500', tool: 'text-blue-500',
          health: 'text-rose-500', podcast: 'text-amber-500',
        };
        return visibleCategories.map((key, i) => (
          <>
            {i > 0 && <div class="w-px bg-stone-200 hidden sm:block self-center h-6"></div>}
            <a href={`/category/${key}`} class="text-center hover:opacity-70 transition-opacity">
              <div class={`text-2xl font-bold ${colors[key]}`}>{allItems.filter(item => item.data.category === key).length}</div>
              <div class="text-sm text-stone-400 mt-0.5">{categoryConfig[key].label}</div>
            </a>
          </>
        ));
      })()}
    </div>
  </div>

  <!-- Category filter tabs -->
  <div class="flex gap-2 mb-8 overflow-x-auto pb-1">
    <a href="/" class="shrink-0 px-4 py-2 rounded-full text-sm font-medium bg-stone-900 text-white">全部</a>
    {visibleCategories.map(key => (
      <a
        href={`/category/${key}`}
        class="shrink-0 px-4 py-2 rounded-full text-sm font-medium text-stone-600 hover:bg-stone-100 transition-colors"
      >
        {categoryConfig[key].label}
      </a>
    ))}
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {sorted.map(item => (
      <ItemCard
        title={item.data.title}
        category={item.data.category}
        tags={item.data.tags}
        rating={item.data.rating}
        summary={item.data.summary}
        cover={item.data.cover}
        slug={item.id}
        country={item.data.country}
      />
    ))}
  </div>
</BaseLayout>
