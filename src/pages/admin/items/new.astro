---
import { allCategories, categoryConfig } from '../../../lib/categories';

const today = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>新增内容 · Admin</title>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased min-h-screen">
    <header class="sticky top-0 z-50 bg-white border-b border-stone-200">
      <div class="max-w-4xl mx-auto px-4 h-14 flex items-center gap-3">
        <a href="/admin/dashboard" class="text-stone-400 hover:text-stone-700 transition-colors text-sm">← 返回</a>
        <span class="text-stone-300">/</span>
        <span class="font-semibold text-sm">新增内容</span>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <form id="item-form" class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Left: main fields -->
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white border border-stone-200 rounded-xl p-5 space-y-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">标题 <span class="text-red-500">*</span></label>
              <input id="f-title" type="text" required class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="内容标题" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">摘要 <span class="text-red-500">*</span></label>
              <textarea id="f-summary" rows="3" required class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors resize-none" placeholder="一两句话介绍这个内容"></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">正文（Markdown）</label>
              <textarea id="f-body" rows="10" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors resize-y font-mono" placeholder="## 小标题&#10;&#10;正文内容…"></textarea>
            </div>
          </div>
        </div>

        <!-- Right: metadata -->
        <div class="space-y-5">
          <div class="bg-white border border-stone-200 rounded-xl p-5 space-y-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">ID（slug）<span class="text-red-500">*</span></label>
              <input id="f-id" type="text" required pattern="[a-zA-Z0-9_-]+" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm font-mono focus:outline-none focus:border-stone-500 transition-colors" placeholder="my-item-slug" />
              <p class="text-xs text-stone-400 mt-1">字母、数字、- 和 _，创建后不可修改</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">分类 <span class="text-red-500">*</span></label>
              <select id="f-category" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors bg-white">
                {allCategories.map(key => (
                  <option value={key}>{categoryConfig[key]?.label ?? key}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">日期 <span class="text-red-500">*</span></label>
              <input id="f-date" type="date" value={today} required class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">国家/地区</label>
              <input id="f-country" type="text" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="美国、中国…" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">标签</label>
              <input id="f-tags" type="text" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="逗号分隔，如：AI, 效率" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">封面图 URL</label>
              <input id="f-cover" type="url" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="https://…" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">链接</label>
              <input id="f-link" type="url" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="https://…" />
            </div>
          </div>

          <div class="flex gap-3">
            <a href="/admin/dashboard" class="flex-1 px-4 py-2.5 text-sm text-center border border-stone-200 rounded-lg hover:bg-stone-50 transition-colors">取消</a>
            <button type="submit" id="submit-btn" class="flex-1 px-4 py-2.5 text-sm bg-stone-900 text-white rounded-lg hover:opacity-90 transition-opacity font-medium">创建</button>
          </div>
          <p id="form-error" class="text-sm text-red-500 hidden"></p>
        </div>
      </form>
    </main>

    <script>
      function slugify(str) {
        return str.toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '')
          .slice(0, 80);
      }

      const titleEl = document.getElementById('f-title');
      const idEl = document.getElementById('f-id');
      let idManual = false;

      idEl.addEventListener('input', () => { idManual = true; });
      titleEl.addEventListener('input', () => {
        if (!idManual) idEl.value = slugify(titleEl.value);
      });

      document.getElementById('item-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        const errEl = document.getElementById('form-error');
        btn.disabled = true;
        btn.textContent = '创建中…';
        errEl.classList.add('hidden');

        const payload = {
          id: idEl.value.trim(),
          title: titleEl.value.trim(),
          summary: document.getElementById('f-summary').value.trim(),
          body: document.getElementById('f-body').value.trim(),
          category: document.getElementById('f-category').value,
          date: document.getElementById('f-date').value,
          country: document.getElementById('f-country').value.trim(),
          tags: document.getElementById('f-tags').value.trim(),
          cover: document.getElementById('f-cover').value.trim(),
          link: document.getElementById('f-link').value.trim(),
        };

        try {
          const res = await fetch('/api/admin/items', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (res.ok) {
            location.href = `/item/${data.id}`;
          } else {
            errEl.textContent = data.error ?? '创建失败';
            errEl.classList.remove('hidden');
            btn.disabled = false;
            btn.textContent = '创建';
          }
        } catch {
          errEl.textContent = '网络错误，请重试';
          errEl.classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = '创建';
        }
      });
    </script>
  </body>
</html>
