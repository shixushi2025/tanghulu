---
import { env } from 'cloudflare:workers';
import { getItemById } from '../../../../lib/db';
import { allCategories, categoryConfig } from '../../../../lib/categories';

const { id } = Astro.params;
const db = env.TANGHULU_DB;
const item = await getItemById(db, id!);

if (!item) return Astro.redirect('/admin/dashboard');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>编辑 · {item.title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased min-h-screen">
    <header class="sticky top-0 z-50 bg-white border-b border-stone-200">
      <div class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <a href="/admin/dashboard" class="shrink-0 text-stone-400 hover:text-stone-700 transition-colors text-sm">← 返回</a>
          <span class="text-stone-300 shrink-0">/</span>
          <span class="font-semibold text-sm truncate">{item.title}</span>
        </div>
        <a href={`/item/${item.id}`} target="_blank" class="shrink-0 text-xs text-stone-400 hover:text-stone-700 transition-colors">预览 ↗</a>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <form id="item-form" class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Left: main fields -->
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white border border-stone-200 rounded-xl p-5 space-y-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">标题 <span class="text-red-500">*</span></label>
              <input id="f-title" type="text" required value={item.title} class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">摘要 <span class="text-red-500">*</span></label>
              <textarea id="f-summary" rows="3" required class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors resize-none">{item.summary}</textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">正文（Markdown）</label>
              <textarea id="f-body" rows="10" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors resize-y font-mono">{item.body}</textarea>
            </div>
          </div>
        </div>

        <!-- Right: metadata -->
        <div class="space-y-5">
          <div class="bg-white border border-stone-200 rounded-xl p-5 space-y-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">ID（slug）</label>
              <input type="text" value={item.id} readonly class="w-full px-3 py-2 border border-stone-100 rounded-lg text-sm font-mono bg-stone-50 text-stone-400 cursor-not-allowed" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">分类 <span class="text-red-500">*</span></label>
              <select id="f-category" class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors bg-white">
                {allCategories.map(key => (
                  <option value={key} selected={key === item.category}>{categoryConfig[key]?.label ?? key}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">日期 <span class="text-red-500">*</span></label>
              <input id="f-date" type="date" value={item.date} required class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">国家/地区</label>
              <input id="f-country" type="text" value={item.country} class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="美国、中国…" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">标签</label>
              <input id="f-tags" type="text" value={item.tags.join(', ')} class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="逗号分隔" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">封面图 URL</label>
              <input id="f-cover" type="url" value={item.cover} class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="https://…" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">链接</label>
              <input id="f-link" type="url" value={item.link} class="w-full px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-stone-500 transition-colors" placeholder="https://…" />
            </div>
          </div>

          <div class="flex gap-3">
            <a href="/admin/dashboard" class="flex-1 px-4 py-2.5 text-sm text-center border border-stone-200 rounded-lg hover:bg-stone-50 transition-colors">取消</a>
            <button type="submit" id="submit-btn" class="flex-1 px-4 py-2.5 text-sm bg-stone-900 text-white rounded-lg hover:opacity-90 transition-opacity font-medium">保存</button>
          </div>
          <p id="form-error" class="text-sm text-red-500 hidden"></p>
        </div>
      </form>
    </main>

    <script define:vars={{ itemId: item.id }}>
      document.getElementById('item-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        const errEl = document.getElementById('form-error');
        btn.disabled = true;
        btn.textContent = '保存中…';
        errEl.classList.add('hidden');

        const payload = {
          title: document.getElementById('f-title').value.trim(),
          summary: document.getElementById('f-summary').value.trim(),
          body: document.getElementById('f-body').value.trim(),
          category: document.getElementById('f-category').value,
          date: document.getElementById('f-date').value,
          country: document.getElementById('f-country').value.trim(),
          tags: document.getElementById('f-tags').value.trim(),
          cover: document.getElementById('f-cover').value.trim(),
          link: document.getElementById('f-link').value.trim(),
        };

        try {
          const res = await fetch(`/api/admin/items/${itemId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (res.ok) {
            location.href = `/item/${itemId}`;
          } else {
            errEl.textContent = data.error ?? '保存失败';
            errEl.classList.remove('hidden');
            btn.disabled = false;
            btn.textContent = '保存';
          }
        } catch {
          errEl.textContent = '网络错误，请重试';
          errEl.classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = '保存';
        }
      });
    </script>
  </body>
</html>
