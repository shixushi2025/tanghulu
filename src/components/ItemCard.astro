---
interface Props {
  title: string;
  category: string;
  tags?: string[];
  rating: number;
  summary: string;
  cover?: string;
  slug: string;
}

const { title, category, tags = [], rating, summary, cover, slug } = Astro.props;

const categoryConfig: Record<string, { label: string; color: string; bg: string }> = {
  film:  { label: '电影', color: 'text-orange-600', bg: 'bg-orange-50' },
  book:  { label: '书籍', color: 'text-green-600',  bg: 'bg-green-50' },
  tool:  { label: 'AI 工具', color: 'text-blue-600', bg: 'bg-blue-50' },
  other: { label: '其他', color: 'text-purple-600', bg: 'bg-purple-50' },
};

const cat = categoryConfig[category] ?? categoryConfig.other;

const initial = title.charAt(0);
const placeholderColors: Record<string, string> = {
  film:  'bg-orange-100 text-orange-400',
  book:  'bg-green-100 text-green-400',
  tool:  'bg-blue-100 text-blue-400',
  other: 'bg-purple-100 text-purple-400',
};
---

<a
  href={`/item/${slug}`}
  class="group block bg-white rounded-2xl border border-stone-200 overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all duration-200"
>
  <!-- Cover -->
  <div class="aspect-[4/3] overflow-hidden">
    {cover ? (
      <img src={cover} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    ) : (
      <div class={`w-full h-full flex items-center justify-center text-5xl font-bold ${placeholderColors[category] ?? placeholderColors.other}`}>
        {initial}
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-4">
    <!-- Category badge -->
    <span class={`inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-2 ${cat.color} ${cat.bg}`}>
      {cat.label}
    </span>

    <!-- Title & Rating -->
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-semibold text-stone-900 leading-tight group-hover:text-orange-500 transition-colors">
        {title}
      </h3>
      <span class="shrink-0 text-sm font-medium text-amber-500 flex items-center gap-0.5">
        ⭐ {rating.toFixed(1)}
      </span>
    </div>

    <!-- Summary -->
    <p class="text-sm text-stone-500 leading-relaxed line-clamp-2">{summary}</p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mt-3">
        {tags.slice(0, 3).map(tag => (
          <span class="text-xs text-stone-400 bg-stone-100 px-2 py-0.5 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
