---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '糖葫芦',
  description = '精选那些值得你时间的东西',
} = Astro.props;

const navItems = [
  { label: '全部', href: '/' },
  { label: '电影', href: '/category/film' },
  { label: '书籍', href: '/category/book' },
  { label: 'AI 工具', href: '/category/tool' },
  { label: '关于', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === '糖葫芦' ? title : `${title} · 糖葫芦`}</title>
  </head>
  <body>
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-stone-50/90 backdrop-blur border-b border-stone-200">
      <div class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-stone-900 hover:text-orange-500 transition-colors">
          <span class="text-2xl">🍡</span>
          <span>糖葫芦</span>
        </a>
        <nav class="flex items-center gap-1">
          {navItems.map(item => (
            <a
              href={item.href}
              class={`px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
                currentPath === item.href
                  ? 'bg-stone-900 text-white'
                  : 'text-stone-600 hover:text-stone-900 hover:bg-stone-100'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-4xl mx-auto px-4 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-stone-200 mt-16">
      <div class="max-w-4xl mx-auto px-4 py-8 text-center text-sm text-stone-400">
        <p>糖葫芦 · 精选那些值得你时间的东西</p>
      </div>
    </footer>
  </body>
</html>
